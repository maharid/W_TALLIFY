# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=w_tallifydb
DB_USER=root
DB_PASSWORD=your_secure_password

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Production
CONNECTIONSTRINGS__TALLIFYDB="server=${DB_HOST};port=${DB_PORT};database=${DB_NAME};user=${DB_USER};password=${DB_PASSWORD};"

# SMTP / Email Settings
EMAILSETTINGS__HOST=smtp.gmail.com
EMAILSETTINGS__PORT=587
EMAILSETTINGS__ENABLESSL=true
EMAILSETTINGS__USERNAME=official-email@gmail.com
EMAILSETTINGS__PASSWORD=your_app_specific_password
EMAILSETTINGS__FROMADDRESS=official-email@gmail.com
EMAILSETTINGS__FROMNAME="Tallify System"

# SignalR / Redis (Optional for scaling)
# REDIS_URL=localhost:6379
