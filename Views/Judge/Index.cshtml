@model ProjectTallify.Models.JudgeViewModel
@{
    Layout = "_ScoringLayout"; 
    ViewBag.JudgeName = Model.JudgeName;
    var allCriteria = Model.Groups.SelectMany(g => g.Criteria).ToList();
}

<main class="judge-main">
    
    <!-- Premium Header -->
    <div class="judge-header-premium">
        <div class="event-branding">
            <h1 class="event-title-premium">@Model.EventTitle</h1>
        </div>
        <div class="status-panel">
            @if (Model.IsRoundActive)
            {
                <div class="status-badge-premium badge-active">
                    <span class="badge-dot standby-pulse"></span>
                    @Model.RoundName
                </div>
            }
            else
            {
                <div class="status-badge-premium badge-standby">
                    Waiting for Round
                </div>
            }
        </div>
    </div>

    @if (Model.EventStatus == "open" && Model.IsRoundActive && !Model.IsSubmitted)
    {
        <div class="scoring-card">
            <!-- Card Header: 85:5:10 Ratio -->
            <div class="card-header-v2">
                <h2 id="currentCriteriaName" class="criteria-title-centered">Loading...</h2>
                
                <div class="header-stats-row">
                    <!-- 85% Progress -->
                    <div class="stats-progress-container">
                        <div class="progress-track-v2">
                            <div id="criteriaProgressBar" class="progress-fill-v2"></div>
                            <span id="progressLabel" class="progress-text-v2">Scored 0 of @Model.Contestants.Count</span>
                        </div>
                    </div>
                    
                    <!-- 5% Separator -->
                    <div class="stats-separator-container">
                        <div class="v-separator"></div>
                    </div>

                    <!-- 10% Weight Highlight -->
                    <div class="stats-weight-container">
                        <div id="criteriaWeight" class="weight-badge-v2">0%</div>
                    </div>
                </div>
            </div>

            <form id="scoring-form">
                @Html.AntiForgeryToken()
                <div class="contestant-carousel-viewport">
                    <div id="contestantGrid" class="contestant-grid">
                        @foreach (var contestant in Model.Contestants)
                        {
                            <div class="contestant-card-v2" data-contestant-id="@contestant.ContestantId">
                                <div class="c-code-v2">@contestant.ContestantId</div>
                                <div class="c-identity-v2">
                                    <span class="c-name-v2">@contestant.FullName</span>
                                    <div class="c-separator"></div>
                                    <span class="c-org-v2">@contestant.Subtitle</span>
                                </div>
                                <div class="c-photo-wrapper" onclick="showPhoto('@contestant.FullName', '@contestant.PhotoPath')">
                                    <div class="c-photo-blur" style="background-image: url('@(contestant.PhotoPath ?? "/images/default pfp.png")');"></div>
                                    <img src="@(contestant.PhotoPath ?? "/images/default pfp.png")" class="c-photo-main" alt="Contestant" />
                                </div>
                                <div class="c-score-v2">
                                    <input type="number" inputmode="decimal" class="score-input-v2" 
                                           data-contestant-id="@contestant.ContestantId" placeholder="Score"
                                           oninput="validateScore(this, false)"
                                           onblur="validateScore(this, true)"
                                           @(Model.IsSubmitted ? "readonly" : "") />
                                </div>
                            </div>
                        }
                    </div>
                    <div id="carouselPagination" class="carousel-pagination"></div>
                </div>
            </form>

            <!-- Standardized 3-Column Footer -->
            <footer class="event-step-footer">
                <div class="event-step-actions" style="flex: 1; display: flex; justify-content: flex-start; padding: 0;">
                    <button type="button" id="btnPrevCriterion" class="btn-outline" disabled>Previous Criterion</button>
                </div>
                
                <div class="footer-col-center" style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px;">
                    <div id="criteriaPagination" class="carousel-pagination" style="margin-top: 0; padding-bottom: 0;"></div>
                </div>

                <div class="event-step-actions" style="flex: 1; display: flex; justify-content: flex-end; padding: 0;">
                    <button type="button" id="btnNextCriterion" class="btn-primary">Next Criterion</button>
                    <button type="button" id="btnFinalSubmit" class="btn-primary hidden" style="background-color: #10B981; border-color: #10B981;">Submit Scores</button>
                </div>
            </footer>
        </div>
    }
    else
    {
        @if (Model.IsSubmitted)
        {
            <!-- Waiting Screen (after submission) -->
            <div class="standby-container text-center standby-floating-card" style="margin: 3rem auto; padding: 3rem; background: white; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); max-width: 500px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <div class="standby-icon standby-pulse" style="font-size: 4rem; margin-bottom: 1.5rem; opacity: 0.5;">
                    ⏳
                </div>
                <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1rem; color: var(--color-text);">
                    Waiting for Next Round
                </h2>
                <p style="font-size: 1.1rem; color: var(--color-text-soft); margin-bottom: 2rem;">
                    Your scores have been submitted. The organizer will notify you when the next round begins.
                </p>
                <button type="button" onclick="window.location.reload()" class="btn-primary" style="max-width: 200px; margin: 0 auto; width: 100%; padding: 12px; border-radius: 8px; font-weight: 600;">
                    Refresh Status
                </button>
            </div>
        }
        else
        {
            <!-- Premium Standby State -->
            <div class="standby-container-v2">
                <div class="standby-card-premium">
                    <div class="standby-icon-wrapper">
                        <div class="standby-pulse-ring"></div>
                        <div class="standby-icon-inner">🕒</div>
                    </div>

                    <div class="standby-content">
                        @if (Model.EventStatus == "closed")
                        {
                            <h2 class="standby-title">Event Closed</h2>
                            <p class="standby-message">This event is currently closed. Please wait for the organizer to open the next session.</p>
                        }
                        else
                        {
                            <h2 class="standby-title">Waiting for Round</h2>
                            <p class="standby-message">Hello <strong>@Model.JudgeName</strong>! Please stay on this screen. The next round will appear here as soon as it's opened by the organizer.</p>
                            <div class="standby-status-pill waiting">
                                <span class="status-dot standby-pulse"></span>
                                Ready to Score
                            </div>
                        }
                    </div>

                    <div class="standby-footer">
                        <p>Real-time updates enabled</p>
                    </div>
                </div>
            </div>
        }
    }
</main>

<!-- Confirmation Modal -->
<div id="confirmSubmitModal" class="summary-overlay">
    <div class="summary-modal" style="max-width: 450px;">
        <div class="summary-modal-header">
            <h3 class="screen-title">Confirm Submission</h3>
            <button type="button" onclick="closeConfirmModal()" class="screen-close-btn" aria-label="Close">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="summary-modal-body" style="text-align: center; padding: 30px 20px;">
            <div style="font-size: 48px; margin-bottom: 20px;">📢</div>
            <p style="color: var(--color-text); font-size: 1.1rem; font-weight: 500; margin-bottom: 10px;">Ready to finalize?</p>
            <p style="color: var(--color-text-soft); line-height: 1.5;">Are you sure you want to submit all scores? This action cannot be undone and will finalize your results for this round.</p>
        </div>
        <div class="screen-actions" style="padding: 20px; border-top: 1px solid var(--color-border); display: flex; gap: 12px;">
            <button type="button" onclick="closeConfirmModal()" class="btn-screen-cancel" style="flex: 1;">Review Again</button>
            <button type="button" id="btnConfirmFinal" onclick="executeFinalSubmission()" class="btn-screen-confirm" style="flex: 1; background: #10B981; border-color: #10B981;">Yes, Submit</button>
        </div>
    </div>
</div>

<!-- Success Submission Modal -->
<div id="successSubmitModal" class="summary-overlay">
    <div class="summary-modal" style="max-width: 450px;">
        <div class="summary-modal-body" style="text-align: center; padding: 40px 20px;">
            <div class="success-icon-large">
                <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            </div>
            <h3 class="screen-title" style="margin-top: 20px; font-size: 1.5rem;">Scores Recorded!</h3>
            <p style="color: var(--color-text-soft); line-height: 1.5; margin-top: 10px;">Your scores for this round have been successfully submitted. You will be redirected to the standby screen.</p>
        </div>
        <div class="screen-actions" style="padding: 20px; border-top: 1px solid var(--color-border);">
            <button type="button" onclick="closeSuccessModal()" class="btn-screen-confirm" style="width: 100%; background: #10B981; border-color: #10B981;">Return to Standby</button>
        </div>
    </div>
</div>

<style>
    /* Standby Premium Styles */
    .standby-container-v2 { flex: 1; display: flex; align-items: center; justify-content: center; padding: 20px; }
    .standby-card-premium { background: #fff; border-radius: 24px; box-shadow: 0 10px 40px rgba(0,0,0,0.08); border: 1px solid var(--color-border); width: 100%; max-width: 500px; padding: 40px; text-align: center; position: relative; overflow: hidden; }
    
    .standby-icon-wrapper { width: 100px; height: 100px; margin: 0 auto 24px; position: relative; display: flex; align-items: center; justify-content: center; }
    .standby-icon-inner { font-size: 50px; z-index: 2; }
    
    .standby-pulse-ring { position: absolute; width: 100%; height: 100%; border: 4px solid var(--color-primary); border-radius: 50%; opacity: 0; animation: standby-ring-pulse 2s infinite; }
    @@keyframes standby-ring-pulse { 0% { transform: scale(0.8); opacity: 0.5; } 100% { transform: scale(1.4); opacity: 0; } }
    
    .success-icon-pulse { width: 80px; height: 80px; background: #D1FAE5; color: #10B981; border-radius: 50%; display: flex; align-items: center; justify-content: center; animation: success-pop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    @@keyframes success-pop { 0% { transform: scale(0.5); } 100% { transform: scale(1); } }
    
    .standby-title { font-size: 1.75rem; font-weight: 800; color: var(--color-text); margin-bottom: 12px; }
    .standby-message { color: var(--color-text-soft); line-height: 1.6; margin-bottom: 24px; font-size: 1.05rem; }
    
    .standby-status-pill { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; border-radius: 20px; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .standby-status-pill.waiting { background: #FEF3C7; color: #D97706; }
    .standby-status-pill.success { background: #D1FAE5; color: #059669; }
    
    .status-dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; }
    .standby-pulse { animation: standby-dot-pulse 1.5s infinite; }
    @@keyframes standby-dot-pulse { 0% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.8); } 100% { opacity: 1; transform: scale(1); } }
    
    .standby-footer { margin-top: 30px; padding-top: 20px; border-top: 1px solid var(--color-border); font-size: 0.75rem; color: var(--color-text-faint); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
    
    .success-icon-large { width: 100px; height: 100px; background: #D1FAE5; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto; }
</style>

<!-- Standardized Toast Container -->
<div id="toast-container" class="toast-container"></div>

@section Scripts {
    <script>
        // 1. DATA NORMALIZATION (PascalCase to consistent properties)
        const rawCriteria = @Html.Raw(Json.Serialize(allCriteria));
        const rawContestants = @Html.Raw(Json.Serialize(Model.Contestants));
        
        const criteria = rawCriteria.map(c => ({
            name: c.name || c.Name,
            minPoints: c.minPoints !== undefined ? c.minPoints : c.MinPoints,
            maxPoints: c.maxPoints !== undefined ? c.maxPoints : c.MaxPoints,
            weightPercentage: c.weightPercentage !== undefined ? c.weightPercentage : c.WeightPercentage
        }));

        const contestants = rawContestants.map(c => ({
            contestantId: c.contestantId || c.ContestantId,
            fullName: c.fullName || c.FullName,
            subtitle: c.subtitle || c.Subtitle,
            photoPath: c.photoPath || c.PhotoPath
        }));

        const eventCode = '@Model.EventCode';
        const roundId = @Model.RoundId;
        const DRAFT_KEY = `tallify_draft_${eventCode}_${roundId}`.replace(/\s+/g, '');
        
        let currentCritIndex = 0;
        let currentCarouselPage = 0;
        const itemsPerPage = 3;

        let grid, critNameEl, critWeightEl, critProgressFill, critProgressLabel, critDots, carouselDots, btnPrevCrit, btnNextCrit, btnFinalSubmit;

        function showToast(msg, type = "error") {
            console.log(`Toast [${type}]: ${msg}`);
            const container = document.getElementById("toast-container");
            if (!container) return;
            const existing = Array.from(container.querySelectorAll(".toast-item")).find(t => t.textContent === msg);
            if (existing) return;
            const t = document.createElement("div");
            t.className = `toast-item toast-${type}`;
            t.textContent = msg;
            container.appendChild(t);
            setTimeout(() => t.classList.add("is-visible"), 10);
            setTimeout(() => {
                t.classList.remove("is-visible");
                setTimeout(() => t.remove(), 300);
            }, 3000);
        }

        function closeConfirmModal() {
            const modal = document.getElementById('confirmSubmitModal');
            if (modal) {
                modal.classList.remove('open');
                setTimeout(() => {
                    modal.style.display = 'none';
                }, 200); // Wait for transition
            }
        }

        function showPhoto(name, path) {
            console.log(`Viewing photo of ${name}: ${path}`);
        }

        /**
         * Real-time Score Validation
         */
        function validateScore(input, showFeedback) {
            if (!criteria || criteria.length === 0) return;
            const crit = criteria[currentCritIndex];
            const val = parseFloat(input.value);
            input.classList.remove('invalid');

            if (isNaN(val)) {
                if (input.value !== "") {
                    input.classList.add('invalid');
                    if (showFeedback) showToast("Please enter a valid number");
                }
                saveToDraft(input.dataset.contestantId, crit.name, "");
                return;
            }

            // Boundary Checks
            if (val < crit.minPoints) {
                input.classList.add('invalid');
                if (showFeedback) showToast("Score is below the minimum score");
            } else if (val > crit.maxPoints) {
                input.classList.add('invalid');
                if (showFeedback) showToast("Score is above the maximum score");
            }

            saveToDraft(input.dataset.contestantId, crit.name, input.value);
        }

        function getDraft() {
            const d = localStorage.getItem(DRAFT_KEY);
            return d ? JSON.parse(d) : {};
        }

        function saveToDraft(cid, cname, val) {
            const draft = getDraft();
            if (!draft[cname]) draft[cname] = {};
            draft[cname][cid] = val;
            localStorage.setItem(DRAFT_KEY, JSON.stringify(draft));
            updateProgress();
        }

        function updateProgress() {
            if (!critProgressFill || !critProgressLabel || !criteria || criteria.length === 0) return;
            const draft = getDraft();
            const currentCrit = criteria[currentCritIndex];
            const scores = draft[currentCrit.name] || {};
            const count = Object.keys(scores).filter(k => scores[k] !== "").length;
            const percent = contestants.length > 0 ? (count / contestants.length) * 100 : 0;
            critProgressFill.style.width = `${percent}%`;
            critProgressLabel.textContent = `Scored ${count} of ${contestants.length}`;
        }

        function renderCriteria() {
            if (!criteria || criteria.length === 0) return;
            const crit = criteria[currentCritIndex];
            if (critNameEl) critNameEl.textContent = crit.name;
            const w = crit.weightPercentage;
            if (critWeightEl) critWeightEl.textContent = (w % 1 === 0 ? w.toFixed(0) : w.toFixed(2)) + "%";

            if (critDots) {
                critDots.innerHTML = '';
                criteria.forEach((_, i) => {
                    const d = document.createElement('div');
                    d.className = `dot static ${i === currentCritIndex ? 'active' : ''}`;
                    d.textContent = i + 1;
                    critDots.appendChild(d);
                });
            }

            const draft = getDraft();
            const critScores = draft[crit.name] || {};
            document.querySelectorAll('.score-input-v2').forEach(input => {
                const cid = input.dataset.contestantId;
                const scoreValue = critScores[cid] || "";
                input.value = scoreValue;
                input.placeholder = `${crit.minPoints}-${crit.maxPoints}`;
                
                input.classList.remove('invalid');
                if (scoreValue !== "") {
                    const val = parseFloat(scoreValue);
                    if (!isNaN(val) && (val < crit.minPoints || val > crit.maxPoints)) {
                        input.classList.add('invalid');
                    }
                }
            });

            updateProgress();
            renderCarousel();

            if (btnPrevCrit) btnPrevCrit.disabled = currentCritIndex === 0;
            if (currentCritIndex === criteria.length - 1) {
                if (btnNextCrit) btnNextCrit.classList.add('hidden');
                if (btnFinalSubmit) btnFinalSubmit.classList.remove('hidden');
            } else {
                if (btnNextCrit) btnNextCrit.classList.remove('hidden');
                if (btnFinalSubmit) btnFinalSubmit.classList.add('hidden');
            }
        }

        function renderCarousel() {
            if (!grid || !carouselDots) return;
            const totalPages = Math.ceil(contestants.length / itemsPerPage);
            const startIndex = currentCarouselPage * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;

            const cards = document.querySelectorAll('.contestant-card-v2');
            cards.forEach((card, idx) => { card.style.display = (idx >= startIndex && idx < endIndex) ? 'flex' : 'none'; });

            grid.classList.toggle('centered', (contestants.length - startIndex) < itemsPerPage);

            carouselDots.innerHTML = '';
            const first = document.createElement('div');
            first.className = `dot ${currentCarouselPage === 0 ? 'active' : ''}`;
            first.textContent = '<< First';
            first.onclick = () => { currentCarouselPage = 0; renderCarousel(); };
            carouselDots.appendChild(first);

            if (totalPages > 2) {
                const mid = document.createElement('div');
                const isMidActive = currentCarouselPage > 0 && currentCarouselPage < totalPages - 1;
                mid.className = `dot ${isMidActive ? 'active' : ''}`;
                mid.textContent = isMidActive ? (currentCarouselPage + 1) : '-';
                mid.classList.add('static');
                carouselDots.appendChild(mid);
            }

            const last = document.createElement('div');
            last.className = `dot ${currentCarouselPage === totalPages - 1 ? 'active' : ''}`;
            last.textContent = 'Last >>';
            last.onclick = () => { currentCarouselPage = totalPages - 1; renderCarousel(); };
            carouselDots.appendChild(last);
        }

        async function executeFinalSubmission() {
            const draft = getDraft();
            const btn = document.getElementById('btnConfirmFinal');
            
            const submissions = contestants.map(c => ({
                contestantCode: c.contestantId.toString(),
                scores: criteria.map(crit => ({
                    criteriaName: crit.name,
                    score: parseFloat(draft[crit.name][c.contestantId])
                }))
            }));

            try {
                if (btn) {
                    btn.disabled = true;
                    btn.textContent = "Submitting...";
                }

                const response = await fetch('/Judge/Submit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.getElementsByName('__RequestVerificationToken')[0]?.value
                    },
                    body: JSON.stringify({ eventCode, roundId, submissions })
                });

                const res = await response.json();
                if (res.success) {
                    localStorage.removeItem(DRAFT_KEY);
                    closeConfirmModal();
                    
                    const successModal = document.getElementById('successSubmitModal');
                    if (successModal) {
                        successModal.style.display = 'flex';
                        setTimeout(() => successModal.classList.add('open'), 10);
                    } else {
                        window.location.reload();
                    }
                } else {
                    showToast(res.message);
                    if (btn) {
                        btn.disabled = false;
                        btn.textContent = "Yes, Submit";
                    }
                }
            } catch (e) {
                console.error("Submission failed:", e);
                showToast("Connection error. Please try again.");
                if (btn) {
                    btn.disabled = false;
                    btn.textContent = "Yes, Submit";
                }
            }
        }

        function closeSuccessModal() {
            const modal = document.getElementById('successSubmitModal');
            if (modal) modal.classList.remove('open');
            setTimeout(() => {
                if (modal) modal.style.display = 'none';
                window.location.reload(); 
            }, 200);
        }

        document.addEventListener('DOMContentLoaded', () => {
            grid = document.getElementById('contestantGrid');
            critNameEl = document.getElementById('currentCriteriaName');
            critWeightEl = document.getElementById('criteriaWeight');
            critProgressFill = document.getElementById('criteriaProgressBar');
            critProgressLabel = document.getElementById('progressLabel');
            critDots = document.getElementById('criteriaPagination');
            carouselDots = document.getElementById('carouselPagination');
            btnPrevCrit = document.getElementById('btnPrevCriterion');
            btnNextCrit = document.getElementById('btnNextCriterion');
            btnFinalSubmit = document.getElementById('btnFinalSubmit');

            if (btnNextCrit) {
                btnNextCrit.addEventListener('click', () => { 
                    currentCritIndex++; currentCarouselPage = 0; renderCriteria(); window.scrollTo(0,0); 
                });
            }
            if (btnPrevCrit) {
                btnPrevCrit.addEventListener('click', () => { 
                    currentCritIndex--; currentCarouselPage = 0; renderCriteria(); window.scrollTo(0,0); 
                });
            }
            if (btnFinalSubmit) {
                btnFinalSubmit.addEventListener('click', () => {
                    console.log("Validation sweep initiated...");
                    const draft = getDraft();
                    
                    for (let cIdx = 0; cIdx < criteria.length; cIdx++) {
                        const c = criteria[cIdx];
                        const scores = draft[c.name] || {};
                        
                        for (let conIdx = 0; conIdx < contestants.length; conIdx++) {
                            const con = contestants[conIdx];
                            const valStr = scores[con.contestantId];
                            const val = parseFloat(valStr);

                            const isMissing = (valStr === undefined || valStr === null || valStr === "");
                            const isInvalid = isNaN(val) || val < c.minPoints || val > c.maxPoints;

                            if (isMissing || isInvalid) {
                                console.warn(`Validation failed: Criteria[${cIdx}], Contestant[${conIdx}], Missing: ${isMissing}, Invalid: ${isInvalid}`);
                                
                                currentCritIndex = cIdx;
                                currentCarouselPage = Math.floor(conIdx / itemsPerPage);
                                renderCriteria();
                                
                                setTimeout(() => {
                                    const targetInput = document.querySelector(`.score-input-v2[data-contestant-id="${con.contestantId}"]`);
                                    if (targetInput) {
                                        targetInput.focus();
                                        targetInput.classList.add('invalid');
                                    }
                                }, 150);

                                if (isMissing) {
                                    showToast(`Missing score for ${con.fullName} in ${c.name}`);
                                } else if (val < c.minPoints) {
                                    showToast("Score is below the minimum score");
                                } else if (val > c.maxPoints) {
                                    showToast("Score is above the maximum score");
                                }
                                
                                return;
                            }
                        }
                    }

                    console.log("Validation sweep passed. Showing confirmation modal.");
                    const modal = document.getElementById('confirmSubmitModal');
                    if (modal) {
                        modal.style.display = 'flex';
                        setTimeout(() => modal.classList.add('open'), 10);
                    } else {
                        console.error("Confirm modal not found!");
                    }
                });
            }

            if (localStorage.getItem(DRAFT_KEY)) showToast("Draft Saved", "success");
            
            // Render initial state if active
            if (criteria && criteria.length > 0) {
                renderCriteria();
            }
        });
    </script>
}
