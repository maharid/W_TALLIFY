@model ProjectTallify.Models.Judge
@{
    ViewData["Title"] = "Access Event";
    Layout = null;
    var themeColor = string.IsNullOrWhiteSpace(Model.Event.ThemeColor) ? "#EC4899" : Model.Event.ThemeColor;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Access Event</title>
    <style>
        :root {
            --color-primary: @themeColor;
            --color-bg: #F2F2F7;
            --color-surface: #FFFFFF;
            --color-text: #1C1C1E;
            --color-text-secondary: #8E8E93;
            --font-stack: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, sans-serif;
            --radius-xl: 28px;
            --shadow-lg: 0 20px 40px rgba(0, 0, 0, 0.1);
        }

        body {
            margin: 0;
            font-family: var(--font-stack);
            background-color: var(--color-bg);
            color: var(--color-text);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .access-card {
            background: var(--color-surface);
            width: 100%;
            max-width: 400px;
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-lg);
            padding: 40px;
            text-align: center;
            animation: fadeIn 0.5s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #E8F5E9;
            color: #2E7D32;
            padding: 6px 12px;
            border-radius: 99px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 24px;
        }

        h1 {
            font-size: 24px;
            font-weight: 800;
            margin: 0 0 8px 0;
        }

        .subtitle {
            font-size: 16px;
            color: var(--color-text-secondary);
            margin-bottom: 32px;
        }

        .event-info-box {
            background: #F8F9FA;
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 32px;
            text-align: left;
        }

        .info-label {
            font-size: 11px;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--color-text-secondary);
            letter-spacing: 0.5px;
            display: block;
            margin-bottom: 4px;
        }

        .info-value {
            font-size: 17px;
            font-weight: 700;
            color: var(--color-text);
            display: block;
            margin-bottom: 16px;
        }

        .btn-enter {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 58px;
            background: var(--color-primary);
            color: white;
            font-size: 17px;
            font-weight: 700;
            border: none;
            border-radius: 18px;
            text-decoration: none;
            transition: all 0.2s;
            box-shadow: 0 8px 16px -4px rgba(0,0,0,0.1);
        }

        .btn-enter:hover {
            filter: brightness(1.1);
            transform: translateY(-2px);
        }

        .btn-enter:active {
            transform: scale(0.98);
        }

        .footer-note {
            margin-top: 24px;
            font-size: 13px;
            color: var(--color-text-secondary);
        }
    </style>
</head>
<body>

    <div class="access-card">
        <div class="status-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Ready to Score
        </div>

        <h1>Welcome, @Model.Name</h1>
        <p class="subtitle">Your secure access is verified.</p>

        <div class="event-info-box">
            <span class="info-label">Current Event</span>
            <span class="info-value">@Model.Event.Name</span>

            <span class="info-label">Role</span>
            <span class="info-value">Official Judge</span>
        </div>
        
        <a href="@Url.Action("Login", "Auth", new { mode = "join", code = Model.Event.AccessCode, pin = Model.Pin })" class="btn-enter">
            Enter Scoring Interface
        </a>

        <p class="footer-note">
            Securely authenticated via Tallify
        </p>
    </div>

</body>
</html>
